<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allows the local-network Ollama preset (http://localhost) without
	     weakening ATS for the public internet. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSHealthShareUsageDescription</key>
	<string>Serenity reads your sleep, resting heart rate and steps to help connect how your body and mood relate, and to personalise your insights.</string>
</dict>
</plist>
