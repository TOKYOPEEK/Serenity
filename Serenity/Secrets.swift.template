import Foundation

/// Bundled default LLM access.
///
/// This file is listed in .gitignore and must never be committed: it carries
/// the obfuscated API key that ships inside the binary. Obfuscation only
/// slows an attacker down — keep a hard spending limit set in the provider
/// console. A committed copy of this file's shape lives in
/// `Secrets.swift.template`.
enum Secrets {
    /// OpenAI-compatible endpoint of the bundled provider ("" = none bundled).
    static let defaultEndpoint = ""

    /// Model to request from the bundled provider ("" = none bundled).
    static let defaultModel = ""

    /// API key of the bundled provider ("" = none bundled).
    static var defaultAPIKey: String {
        guard !obfuscated.isEmpty, !mask.isEmpty else { return "" }
        return String(
            bytes: obfuscated.enumerated().map { $0.element ^ mask[$0.offset % mask.count] },
            encoding: .utf8
        ) ?? ""
    }

    // Generated by xor-ing the key bytes with `mask`; regenerate both together.
    private static let mask: [UInt8] = []
    private static let obfuscated: [UInt8] = []
}
